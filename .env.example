# ─────────────────────────────────────────
# DevOS Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────

# Groq AI (get free key at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# Supabase (get from supabase.com project settings)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# GitHub
# Webhook secret: create any random string, use same in GitHub webhook settings
GITHUB_WEBHOOK_SECRET=your_random_secret_here
# Personal access token: github.com → Settings → Developer Settings → PAT
# Permissions needed: repo (read), user (read)
GITHUB_TOKEN=ghp_your_token_here

# Resend (free at resend.com - for Module 3 emails)
RESEND_API_KEY=re_your_key_here

# Frontend (Next.js)
# These are the public-facing API URLs after deployment
NEXT_PUBLIC_MODULE1_URL=http://localhost:8001
NEXT_PUBLIC_MODULE2_URL=http://localhost:8002
NEXT_PUBLIC_MODULE3_URL=http://localhost:8003
NEXT_PUBLIC_MODULE4_URL=http://localhost:8004
NEXT_PUBLIC_MODULE5_URL=http://localhost:8005
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
